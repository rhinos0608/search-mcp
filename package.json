{
  "name": "search-mcp",
  "version": "2.0.0",
  "description": "MCP server providing web search, web read, GitHub, YouTube, Reddit, Twitter/X, Product Hunt, patent, podcast, and academic research tools",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "search-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:json": "tsx watch src/index.ts -- --json",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "start:json": "node dist/index.js --json",
    "test": "node scripts/run-tests.cjs",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src docs",
    "format:check": "prettier --check src docs",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "config:encrypt": "tsx scripts/encrypt-config.ts",
    "config:decrypt": "tsx scripts/decrypt-config.ts"
  },
  "dependencies": {
    "@huggingface/tokenizers": "^0.1.3",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^11.10.0",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.0",
    "jsdom": "^29.0.1",
    "onnxruntime-node": "^1.24.3",
    "pino": "^9.0.0",
    "youtube-transcript": "^1.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.0.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.25.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
